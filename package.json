{
    "name": "npm-scripts-play",
    "displayName": "npm Scripts Play ▶",
    "description": "Adds ▶ Run CodeLens actions for package.json scripts.",
    "version": "0.1.4",
    "publisher": "Dev-kitx",
    "repository": {
        "type": "git",
        "url": "https://github.com/Dev-kitx/vscode-npm-play"
    },
    "bugs": {
        "url": "https://github.com/Dev-kitx/vscode-npm-play/issues"
    },
    "homepage": "https://github.com/Dev-kitx/vscode-npm-play#readme",
    "engines": {
        "vscode": "^1.109.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "workspaceContains:package.json"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "npmPlay.runScript",
                "title": "Devkitx: Run package.json Script"
            },
            {
                "command": "npmPlay.runScriptDebug",
                "title": "Devkitx: Debug package.json Script"
            },
            {
                "command": "npmPlay.launcher",
                "title": "Devkitx: Script Launcher"
            },
            {
                "command": "npmPlay.togglePin",
                "title": "Devkitx: Pin / Unpin Script"
            },
            {
                "command": "npmPlay.rerunFromHistory",
                "title": "Devkitx: Re-run Script from History"
            }
        ],
        "configuration": {
            "title": "Devkitx Script Runner",
            "properties": {
                "npmPlay.packageManager": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "npm",
                        "yarn",
                        "pnpm"
                    ],
                    "default": "auto",
                    "description": "Which package manager to use. 'auto' picks based on lock files."
                },
                "npmPlay.showDebugLens": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show a Debug CodeLens for scripts."
                },
                "npmPlay.terminalName": {
                    "type": "string",
                    "default": "Devkitx Scripts",
                    "description": "Name of the integrated terminal used to run scripts."
                },
                "npmPlay.enableStatusBar": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show Devkitx ▶ status bar launcher."
                },
                "npmPlay.dangerConfirm": {
                    "type": "boolean",
                    "default": true,
                    "description": "Ask for confirmation before running potentially destructive scripts (clean/rm/reset/prune/etc.)."
                },
                "npmPlay.terminalPerScript": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use a dedicated terminal per script (better reuse + clearer output)."
                },
                "npmPlay.notifyAfterMs": {
                    "type": "number",
                    "default": 0,
                    "description": "Show a notification when a script finishes and took longer than this many milliseconds. Set to 0 to disable (default)."
                }
            }
        },
        "views": {
            "explorer": [
                {
                    "id": "npmPlay.historyView",
                    "name": "Script History",
                    "when": "workspaceContains:package.json"
                }
            ]
        }
    },
    "scripts": {
        "typecheck": "tsc -p . --noEmit",
        "bundle": "node esbuild.js",
        "bundle:watch": "node esbuild.js --watch",
        "vscode:prepublish": "npm run typecheck && npm run bundle",
        "watch": "tsc -watch -p .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "deploy": "vsce publish"
    },
    "devDependencies": {
        "@types/node": "^20.19.33",
        "@types/vscode": "^1.110.0",
        "@vitest/coverage-v8": "^4.0.18",
        "esbuild": "^0.28.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.3"
    },
    "keywords": [
        "vscode",
        "extension",
        "npm",
        "yarn",
        "pnpm",
        "dependency management",
        "dev tools"
    ],
    "author": "akashb",
    "license": "MIT",
    "galleryBanner": {
        "color": "#0f172a",
        "theme": "dark"
    }
}
